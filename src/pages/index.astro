<html>
<head>
  <meta charset="utf-8" />
  <meta http-equiv="refresh" content="0;url=/es/" />
  <title>Redirecting…</title>
</head>
<body>
  <script is:inline>
    const lang = (navigator.language || '').toLowerCase();
    if (lang.startsWith('en')) {
      window.location.replace('/en/');
    } else {
      window.location.replace('/es/');
    }
  </script>
  <noscript>
    <meta http-equiv="refresh" content="0;url=/es/" />
  </noscript>
</body>
</html>
