---
import type { Lang } from '../i18n/utils';
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="experience" data-section="experience" aria-label={t.experience.label}>
  <div class="section-inner">
    <p class="section-label reveal">{t.experience.label}</p>
    <h2 class="reveal reveal-delay-1">{t.experience.title}</h2>

    <div class="experience-card glass-card reveal reveal-delay-2">
      <div class="experience-layout">
        <!-- Content -->
        <div class="experience-content">
          <div class="experience-header">
            <h3 class="experience-company">{t.experience.company}</h3>
            <span class="experience-badge">{t.experience.duration}</span>
          </div>
          <p class="experience-role">{t.experience.role}</p>
          <div class="experience-meta">
            <span class="experience-industry">{t.experience.industry}</span>
            <span class="experience-period">{t.experience.period}</span>
          </div>

          <ul class="experience-list">
            {t.experience.responsibilities.map((item: string) => (
              <li class="experience-list-item">
                <span class="list-indicator"></span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Visual -->
        <div class="experience-visual">
          <div class="monitor">
            <div class="monitor-screen">
              <div class="screen-content">
                <div class="brand-icon">
                  <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 2L2 7l10 5 10-5-10-5z"/>
                    <path d="M2 17l10 5 10-5"/>
                    <path d="M2 12l10 5 10-5"/>
                  </svg>
                </div>
                <span class="brand-name">Fidelity</span>
                <span class="brand-sub">Marketing</span>
              </div>
            </div>
            <div class="monitor-stand">
              <div class="monitor-neck"></div>
              <div class="monitor-base"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .experience-layout {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 3rem;
    align-items: center;
  }

  .experience-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.5rem;
    flex-wrap: wrap;
  }

  .experience-company {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 2.5vw, 1.8rem);
    font-weight: 600;
    letter-spacing: -0.02em;
  }

  .experience-badge {
    display: inline-flex;
    align-items: center;
    padding: 0.3rem 0.85rem;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    color: var(--accent-blue);
    background: rgba(37, 99, 235, 0.12);
    border: 1px solid rgba(37, 99, 235, 0.2);
    border-radius: 980px;
  }

  .experience-role {
    font-size: 1.05rem;
    font-weight: 500;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
  }

  .experience-meta {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }

  .experience-industry,
  .experience-period {
    font-size: 0.88rem;
    color: var(--text-tertiary);
  }

  .experience-list {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  .experience-list-item {
    display: flex;
    gap: 0.85rem;
    align-items: flex-start;
    font-size: 0.95rem;
    color: var(--text-secondary);
    line-height: 1.65;
  }

  .list-indicator {
    flex-shrink: 0;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent-violet);
    margin-top: 0.55rem;
    opacity: 0.7;
  }

  /* Monitor Visual */
  .experience-visual {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .monitor {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .monitor-screen {
    width: 260px;
    height: 170px;
    border-radius: 14px;
    background: linear-gradient(145deg, rgba(37, 99, 235, 0.08), rgba(124, 58, 237, 0.06));
    border: 1px solid rgba(255, 255, 255, 0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }

  .monitor-screen::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 30% 40%, rgba(37, 99, 235, 0.15) 0%, transparent 60%);
  }

  .screen-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    z-index: 1;
  }

  .brand-icon {
    color: var(--accent-blue);
    opacity: 0.8;
  }

  .brand-name {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--text-primary);
  }

  .brand-sub {
    font-size: 0.78rem;
    font-weight: 400;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-tertiary);
  }

  .monitor-stand {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .monitor-neck {
    width: 2px;
    height: 24px;
    background: rgba(255, 255, 255, 0.1);
  }

  .monitor-base {
    width: 60px;
    height: 2px;
    border-radius: 2px;
    background: rgba(255, 255, 255, 0.1);
  }

  @media (max-width: 860px) {
    .experience-layout {
      grid-template-columns: 1fr;
    }

    .experience-visual {
      order: -1;
    }

    .monitor-screen {
      width: 220px;
      height: 144px;
    }
  }
</style>
