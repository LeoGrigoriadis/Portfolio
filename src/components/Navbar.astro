---
import type { Lang } from '../i18n/utils';
import { useTranslations, getAlternateLang } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const altLang = getAlternateLang(lang);
---

<nav id="navbar" class="navbar" aria-label="Main navigation">
  <div class="navbar-inner">
    <!-- Logo -->
    <a href={`/${lang}/`} class="navbar-logo" aria-label="Home">
      <span class="logo-text">LG</span>
      <span class="logo-dot"></span>
    </a>

    <!-- Desktop Links -->
    <div class="nav-links" id="nav-links">
      <a href="#hero" class="nav-link active">{t.nav.about}</a>
      <a href="#experience" class="nav-link">{t.nav.experience}</a>
      <a href="#education" class="nav-link">{t.nav.education}</a>
      <a href="#techstack" class="nav-link">{t.nav.stack}</a>
      <a href="#contact" class="nav-link">{t.nav.contact}</a>
    </div>

    <!-- Actions -->
    <div class="nav-actions">
      <!-- Email -->
      <a
        href="mailto:leonelgrigoriadist5@gmail.com"
        class="nav-icon"
        aria-label="Email"
        title="leonelgrigoriadist5@gmail.com"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="4" width="20" height="16" rx="2"/>
          <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
        </svg>
      </a>

      <!-- LinkedIn -->
      <a
        href="https://www.linkedin.com/in/leonel-grigoriadis/"
        target="_blank"
        rel="noopener noreferrer"
        class="nav-icon"
        aria-label="LinkedIn"
        title="LinkedIn"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
      </a>

      <!-- GitHub -->
      <a
        href="https://github.com/LeoGrigoriadis"
        target="_blank"
        rel="noopener noreferrer"
        class="nav-icon"
        aria-label="GitHub"
        title="GitHub"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
        </svg>
      </a>

      <!-- Language Switch -->
      <a
        href={`/${altLang}/`}
        class="lang-switch"
        aria-label={altLang === 'es' ? 'Cambiar a Español' : 'Switch to English'}
      >
        {t.lang_switch}
      </a>

      <!-- Mobile Menu Toggle -->
      <button
        id="menu-toggle"
        class="menu-toggle"
        aria-label="Menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <span class="menu-bar"></span>
        <span class="menu-bar"></span>
        <span class="menu-bar"></span>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="mobile-menu">
    <div class="mobile-menu-links">
      <a href="#hero" class="mobile-link">{t.nav.about}</a>
      <a href="#experience" class="mobile-link">{t.nav.experience}</a>
      <a href="#education" class="mobile-link">{t.nav.education}</a>
      <a href="#techstack" class="mobile-link">{t.nav.stack}</a>
      <a href="#contact" class="mobile-link">{t.nav.contact}</a>
    </div>
    <div class="mobile-menu-footer">
      <a href="mailto:leonelgrigoriadist5@gmail.com" class="mobile-contact">leonelgrigoriadist5@gmail.com</a>
      <div class="mobile-social">
        <a href="https://www.linkedin.com/in/leonel-grigoriadis/" target="_blank" rel="noopener noreferrer">LinkedIn</a>
        <span class="mobile-divider">·</span>
        <a href="https://github.com/LeoGrigoriadis" target="_blank" rel="noopener noreferrer">GitHub</a>
      </div>
      <a href={`/${altLang}/`} class="mobile-lang">{t.lang_switch}</a>
    </div>
  </div>
</nav>

<style>
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding: 0 clamp(1.25rem, 4vw, 3rem);
    height: var(--navbar-height);
    transition: background 0.4s ease, border-color 0.4s ease, backdrop-filter 0.4s ease;
  }

  .navbar.scrolled {
    background: rgba(10, 10, 10, 0.72);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .navbar-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
    max-width: 1400px;
    margin: 0 auto;
  }

  /* Logo */
  .navbar-logo {
    display: flex;
    align-items: center;
    gap: 4px;
    z-index: 101;
  }

  .logo-text {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--text-primary);
  }

  .logo-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent-blue);
  }

  /* Nav Links */
  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .nav-link {
    padding: 0.45rem 1rem;
    font-size: 0.85rem;
    font-weight: 400;
    color: var(--text-tertiary);
    border-radius: 980px;
    transition: color var(--transition-fast), background var(--transition-fast);
  }

  .nav-link:hover {
    color: var(--text-primary);
  }

  .nav-link.active {
    color: var(--text-primary);
    background: rgba(255, 255, 255, 0.06);
  }

  /* Actions */
  .nav-actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    z-index: 101;
  }

  .nav-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    color: var(--text-tertiary);
    transition: color var(--transition-fast), background var(--transition-fast);
  }

  .nav-icon:hover {
    color: var(--text-primary);
    background: rgba(255, 255, 255, 0.06);
  }

  .lang-switch {
    padding: 0.4rem 0.9rem;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    color: var(--text-tertiary);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 980px;
    transition: color var(--transition-fast), border-color var(--transition-fast), background var(--transition-fast);
  }

  .lang-switch:hover {
    color: var(--text-primary);
    border-color: rgba(255, 255, 255, 0.2);
    background: rgba(255, 255, 255, 0.04);
  }

  /* Hamburger */
  .menu-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    width: 36px;
    height: 36px;
    gap: 5px;
    padding: 0;
  }

  .menu-bar {
    display: block;
    width: 20px;
    height: 1.5px;
    background: var(--text-primary);
    border-radius: 2px;
    transition: transform 0.35s var(--ease-out-expo), opacity 0.25s ease;
    transform-origin: center;
  }

  .menu-toggle.open .menu-bar:nth-child(1) {
    transform: translateY(6.5px) rotate(45deg);
  }
  .menu-toggle.open .menu-bar:nth-child(2) {
    opacity: 0;
  }
  .menu-toggle.open .menu-bar:nth-child(3) {
    transform: translateY(-6.5px) rotate(-45deg);
  }

  /* Mobile Menu */
  .mobile-menu {
    position: fixed;
    inset: 0;
    z-index: 99;
    background: rgba(5, 5, 5, 0.96);
    backdrop-filter: blur(30px);
    -webkit-backdrop-filter: blur(30px);
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding: 5rem 2rem 3rem;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.4s ease;
  }

  .mobile-menu.open {
    opacity: 1;
    pointer-events: all;
  }

  .mobile-menu-links {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    margin-bottom: auto;
    padding-top: 2rem;
  }

  .mobile-link {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--text-secondary);
    padding: 0.5rem 1rem;
    transition: color var(--transition-fast);
  }

  .mobile-link:hover {
    color: var(--text-primary);
  }

  .mobile-menu-footer {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    padding-top: 2rem;
  }

  .mobile-contact {
    font-size: 0.85rem;
    color: var(--text-tertiary);
    transition: color var(--transition-fast);
  }

  .mobile-contact:hover {
    color: var(--text-primary);
  }

  .mobile-social {
    display: flex;
    gap: 0.5rem;
    font-size: 0.85rem;
    color: var(--text-tertiary);
  }

  .mobile-social a {
    transition: color var(--transition-fast);
  }

  .mobile-social a:hover {
    color: var(--text-primary);
  }

  .mobile-divider {
    opacity: 0.3;
  }

  .mobile-lang {
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    color: var(--text-tertiary);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 980px;
    padding: 0.4rem 1.2rem;
    transition: color var(--transition-fast), border-color var(--transition-fast);
  }

  .mobile-lang:hover {
    color: var(--text-primary);
    border-color: rgba(255, 255, 255, 0.2);
  }

  /* Responsive */
  @media (max-width: 860px) {
    .nav-links {
      display: none;
    }
    .nav-icon {
      display: none;
    }
    .lang-switch {
      display: none;
    }
    .menu-toggle {
      display: flex;
    }
  }
</style>
